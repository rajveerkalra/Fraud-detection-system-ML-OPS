{
  "id": null,
  "uid": "model-service",
  "title": "Model Service",
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Predictions total",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [
        { "expr": "sum(model_service_predictions_total)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "type": "timeseries",
      "title": "Predict RPS (ok)",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "rate(model_service_requests_total{endpoint=\"/predict\",status=\"ok\"}[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Predict RPS (error)",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "rate(model_service_requests_total{endpoint=\"/predict\",status=\"error\"}[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 predict latency (s)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_service_predict_latency_seconds_bucket[1m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p50 predict latency (s)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(model_service_predict_latency_seconds_bucket[1m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Predictions by decision (rate)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(model_service_predictions_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Missing online features (rate)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (feature) (rate(model_service_feature_missing_total[1m]))",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}

